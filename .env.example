# client-injected at build time (safe to expose)
VITE_VAPID_PUBLIC_KEY=

# server-only — never prefix with VITE_
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# vercel kv (auto-set when you add the integration)
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=

# vercel cron auth — set this in vercel env, sent as `Authorization: Bearer ...`
CRON_SECRET=
